# ─── Variáveis de ambiente — Nativos Studio Pro ───────────────────────────────
# Copie este arquivo para .env (backend) e configure nas plataformas de deploy.
# Vercel: Project Settings → Environment Variables
# Netlify: Site Settings → Environment Variables

# Supabase — backend Python (server.py) e webhook serverless
SUPABASE_URL=https://blqvsglspdayrznnbzzf.supabase.co
SUPABASE_KEY=           # service_role key (para o backend FastAPI local)
SUPABASE_SERVICE_KEY=   # idem — usado pelo webhook da Kiwify

# Autenticação JWT (backend FastAPI local)
SESSION_SECRET=         # string aleatória longa e segura

# Kiwify webhook — validação do token enviado pela Kiwify
KIWIFY_WEBHOOK_TOKEN=   # token configurado no painel da Kiwify
